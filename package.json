{
  "name": "ahmed-x86-asm",
  "publisher": "ahmed-x86",
  "displayName": "ahmed-x86 asm",
  "description": "Powerful, all-in-one tool to instantly compile and run x86 Assembly code on Linux and Windows.",
  "version": "1.1.1",
  "icon": "icon.png",
  "license": "GPL-3.0-or-later",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ahmed",
    "ahmed-x86",
    "ahmed-x86 asm",
    "assembly",
    "asm",
    "x86",
    "nasm",
    "uasm",
    "irvine",
    "linux",
    "windows",
    "x86-64",
    "runner",
    "compiler",
    "gcc",
    "masm",
    "mingw",
    "fasm",
    "ahmed x86 asm",
    "ahmed_x86 asm",
    "ahmed_x86_asm",
    "x64",
    "x86_64",
    "32bit",
    "64bit",
    "gdb",
    "ahmed-x86 asm"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:ahmed-x86-asm.run",
    "onCommand:ahmed-x86-asm.resetIrvinePath",
    "onCommand:ahmed-x86-asm.checkDeps",
    "onLanguage:assembly",
    "onLanguage:asm",
    "onLanguage:masm",
    "onLanguage:nasm",
    "onLanguage:fasm"
  ],
  "contributes": {
    "snippets": [
      {
        "language": "assembly",
        "path": "./snippets.json"
      },
      {
        "language": "asm",
        "path": "./snippets.json"
      },
      {
        "language": "masm",
        "path": "./snippets.json"
      },
      {
        "language": "nasm",
        "path": "./snippets.json"
      },
      {
        "language": "fasm",
        "path": "./snippets.json"
      }
    ],
    "languages": [
      {
        "id": "assembly",
        "extensions": [
          ".asm",
          ".s",
          ".inc",
          ".nasm",
          ".masm",
          ".uasm"
        ],
        "aliases": [
          "Assembly",
          "asm",
          "x86 Assembly"
        ]
      }
    ],
    "commands": [
      {
        "command": "ahmed-x86-asm.run",
        "title": "Run x86 Assembly (ahmed_x86)",
        "icon": "$(play)"
      },
      {
        "command": "ahmed-x86-asm.resetIrvinePath",
        "title": "Reset Irvine Library Path"
      },
      {
        "command": "ahmed-x86-asm.checkDeps",
        "title": "Check ASM Dependencies (ahmed_x86)"
      }
    ],
    "keybindings": [
      {
        "command": "ahmed-x86-asm.run",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus && (resourceLangId == assembly || resourceExtname =~ /\\.(asm|s|S|inc|nasm|masm|uasm)$/)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "ahmed-x86-asm.run",
          "group": "navigation@1",
          "when": "resourceLangId == assembly || resourceExtname =~ /\\.(asm|s|S|inc|mac|nasm|masm|uasm)$/"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1"
  }
}
