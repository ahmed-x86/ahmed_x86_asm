  "Win32 Standalone (main)": {
    "prefix": "win32-std-main",
    "body": [
      "extern _GetStdHandle@4",
      "extern _WriteFile@20",
      "extern _ExitProcess@4",
      "",
      "global _main",
      "",
      "section .data",
      "\tmsg db \"2. Task 7 Success: Win32 Standalone works directly via Windows API!\", 10",
      "\tmsg_len equ $ - msg",
      "",
      "section .bss",
      "\twritten resd 1",
      "",
      "section .text",
      "_main:",
      "\tpush -11",
      "\tcall _GetStdHandle@4",
      "",
      "\tpush 0",
      "\tpush written",
      "\tpush msg_len",
      "\tpush msg",
      "\tpush eax",
      "\tcall _WriteFile@20",
      "",
      "\tpush 0",
      "\tcall _ExitProcess@4"
    ],
    "description": "Win32 Standalone template using main and Windows API"
  },
  "Win32 Standalone (_start)": {
    "prefix": "win32-std-start",
    "body": [
      "; bywindows.asm - pure Windows API 32-bit",
      "section .data",
      "\tmsg db 'hi i use arch btw from win32 windows 10 pro', 10, 0",
      "\tmsg_len equ $-msg",
      "",
      "section .bss",
      "\twritten resd 1",
      "",
      "section .text",
      "\tglobal _start",
      "\textern _GetStdHandle@4",
      "\textern _WriteConsoleA@20",
      "\textern _ExitProcess@4",
      "",
      "_start:",
      "\tpush -11",
      "\tcall _GetStdHandle@4",
      "",
      "\tpush 0",
      "\tpush written",
      "\tpush msg_len",
      "\tpush msg",
      "\tpush eax",
      "\tcall _WriteConsoleA@20",
      "",
      "\tpush 0",
      "\tcall _ExitProcess@4"
    ],
    "description": "Win32 Standalone template using _start"
  },
  "Win64 Standalone (main)": {
    "prefix": "win64-std-main",
    "body": [
      "extern GetStdHandle",
      "extern WriteFile",
      "extern ExitProcess",
      "",
      "global main",
      "",
      "section .data",
      "\tmsg db \"3. Task 8 Success: Win64 Standalone is running beautifully on Arch!\", 10",
      "\tmsg_len equ $ - msg",
      "",
      "section .bss",
      "\twritten resq 1",
      "",
      "section .text",
      "main:",
      "\tsub rsp, 40",
      "",
      "\tmov rcx, -11",
      "\tcall GetStdHandle",
      "",
      "\tmov rcx, rax",
      "\tlea rdx, [rel msg]",
      "\tmov r8, msg_len",
      "\tlea r9, [rel written]",
      "\tmov qword [rsp+32], 0",
      "\tcall WriteFile",
      "",
      "\txor rcx, rcx",
      "\tcall ExitProcess"
    ],
    "description": "Win64 Standalone template using main"
  },
  "Win64 Standalone (_start)": {
    "prefix": "win64-std-start",
    "body": [
      "; bywindows64.asm - Windows API 64-bit",
      "section .data",
      "\tmsg db 'hi i use arch btw by win64 from windows10pro', 10, 0",
      "\tmsg_len equ $-msg",
      "",
      "section .bss",
      "\twritten resq 1",
      "",
      "section .text",
      "\tglobal _start",
      "\textern GetStdHandle",
      "\textern WriteConsoleA",
      "\textern ExitProcess",
      "",
      "_start:",
      "\tsub rsp, 40",
      "",
      "\tmov rcx, -11",
      "\tcall GetStdHandle",
      "",
      "\tmov rcx, rax",
      "\tmov rdx, msg",
      "\tmov r8, msg_len",
      "\tmov r9, written",
      "\tmov qword [rsp + 32], 0",
      "\tcall WriteConsoleA",
      "",
      "\tmov rcx, 0",
      "\tcall ExitProcess"
    ],
    "description": "Win64 Standalone template using _start"
  },
  "macOS 64-bit (main)": {
    "prefix": "mac64-main",
    "body": [
      "default rel",
      "",
      "global _main",
      "extern _write",
      "",
      "section .data",
      "\tmsg db \"Hello macOS 64-bit from Arch Linux! (The Apple Way)\", 10",
      "\tlen equ $ - msg",
      "",
      "section .text",
      "_main:",
      "\t; Stack Alignment (16-byte boundary)",
      "\tsub rsp, 8",
      "",
      "\tmov rdi, 1          ; fd = 1 (stdout)",
      "\tlea rsi, [msg]      ; load effective address (rel)",
      "\tmov rdx, len        ; length",
      "\tcall _write         ; Apple System Call",
      "",
      "\tadd rsp, 8          ; restore stack",
      "\txor rax, rax        ; return 0",
      "\tret"
    ],
    "description": "Template for macOS 64-bit using main (Apple official method)"
  },
  "FreeBSD 64-bit (_start)": {
    "prefix": "freebsd64-start",
    "body": [
      "; freebsd64.asm - Hello World for FreeBSD 64-bit",
      "section .data",
      "\tmsg db \"Hello from FreeBSD 64-bit on Arch Linux!\", 10",
      "\tlen equ $ - msg",
      "",
      "section .text",
      "\tglobal _start",
      "",
      "_start:",
      "\t; 1. sys_write (FreeBSD rax = 4)",
      "\tmov rax, 4          ; syscall for sys_write in FreeBSD",
      "\tmov rdi, 1          ; stdout",
      "\tmov rsi, msg        ; message address",
      "\tmov rdx, len        ; message length",
      "\tsyscall",
      "",
      "\t; 2. sys_exit (FreeBSD rax = 1)",
      "\tmov rax, 1          ; syscall for sys_exit in FreeBSD",
      "\txor rdi, rdi        ; exit status 0",
      "\tsyscall"
    ],
    "description": "Template for FreeBSD 64-bit using _start (Raw Syscalls)"
  },
