{
  "Linux 32-bit (main)": {
    "prefix": "linux32-main",
    "body": [
      "section .data",
      "\tmsg db \"Success: Linux 32-bit (x86) is running perfectly on Arch!\", 10",
      "\tlen equ $ - msg",
      "",
      "section .text",
      "\tglobal main          ; تعريف main لتعمل مع الخيار الرابع",
      "",
      "main:",
      "\t; استدعاء النظام للطباعة (sys_write = 4 في 32-بت)",
      "\tmov eax, 4           ; رقم أمر الطباعة",
      "\tmov ebx, 1           ; الطباعة على الشاشة (stdout)",
      "\tmov ecx, msg         ; عنوان الرسالة",
      "\tmov edx, len         ; طول الرسالة",
      "\tint 0x80             ; استدعاء النواة (Kernel Interrupt)",
      "",
      "\t; استدعاء النظام للإغلاق (sys_exit = 1 في 32-بت)",
      "\tmov eax, 1           ; رقم أمر الإغلاق",
      "\txor ebx, ebx         ; كود الخروج 0 (بدون أخطاء)",
      "\tint 0x80             ; استدعاء النواة"
    ],
    "description": "Template for Linux 32-bit using main"
  },
  "Linux 32-bit (_start)": {
    "prefix": "linux32-start",
    "body": [
      "section .data",
      "\tmsg db \"Hello from Linux 32-bit (x86) using standard _start!\", 10",
      "\tlen equ $ - msg",
      "",
      "section .text",
      "\tglobal _start",
      "",
      "_start:",
      "\t; sys_write (eax = 4)",
      "\tmov eax, 4",
      "\tmov ebx, 1",
      "\tmov ecx, msg",
      "\tmov edx, len",
      "\tint 0x80",
      "",
      "\t; sys_exit (eax = 1)",
      "\tmov eax, 1",
      "\txor ebx, ebx",
      "\tint 0x80"
    ],
    "description": "Template for Linux 32-bit using _start"
  },
  "Linux 64-bit (main)": {
    "prefix": "linux64-main",
    "body": [
      "section .data",
      "\tmsg db \"Hello from Arch Linux (64-bit Native) using main!\", 10",
      "\tlen equ $ - msg",
      "",
      "section .text",
      "\tglobal main",
      "",
      "main:",
      "\tmov rax, 1       ; sys_write",
      "\tmov rdi, 1       ; stdout",
      "\tmov rsi, msg",
      "\tmov rdx, len",
      "\tsyscall",
      "",
      "\tmov rax, 60      ; sys_exit",
      "\txor rdi, rdi     ; exit code 0",
      "\tsyscall"
    ],
    "description": "Template for Linux 64-bit using main"
  },
