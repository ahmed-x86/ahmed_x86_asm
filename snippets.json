  "win_arm64_start": {
    "prefix": "win-arm64-start",
    "body": [
      ".data",
      "\tmsg: .ascii \"hi i use arch btw by win-arm64\\n\"",
      "\tlen = . - msg",
      "",
      ".bss",
      "\t.align 3",
      "\twritten: .space 8",
      "",
      ".text",
      "\t.global _start",
      "",
      "_start:",
      "\t/* محاذاة المكدس (Stack Alignment) بـ 16 بايت وهو شرط في بيئة Windows ARM64 */",
      "\tsub sp, sp, #32",
      "",
      "\t/* استدعاء GetStdHandle(-11) */",
      "\t/* -11 تعني STD_OUTPUT_HANDLE */",
      "\tmov x0, -11",
      "\tbl GetStdHandle",
      "",
      "\t/* استدعاء WriteConsoleA */",
      "\t/* مقبض الشاشة (Handle) موجود مسبقاً في x0 لأنه ناتج الدالة السابقة */",
      "\tldr x1, =msg        /* المعامل الثاني: عنوان النص */",
      "\tldr x2, =len        /* المعامل الثالث: طول النص */",
      "\tldr x3, =written    /* المعامل الرابع: متغير حفظ عدد البايتات المكتوبة */",
      "\tmov x4, #0          /* المعامل الخامس: NULL */",
      "\tbl WriteConsoleA",
      "",
      "\t/* استدعاء ExitProcess(0) */",
      "\tmov x0, #0",
      "\tbl ExitProcess"
    ],
    "description": "Template for Windows ARM64 using _start"
  },
  "win_arm64_main": {
    "prefix": "win-arm64-main",
    "body": [
      ".data",
      "\tmsg: .ascii \"hi i use arch btw by win-arm64\\n\"",
      "\tlen = . - msg",
      "",
      ".bss",
      "\t.align 3",
      "\twritten: .space 8",
      "",
      ".text",
      "\t.global main",
      "",
      "main:",
      "\t/* حفظ مسجل العودة (x30/lr) ومؤشر الإطار (x29/fp) في المكدس */",
      "\tstp x29, x30, [sp, #-32]!",
      "\tmov x29, sp",
      "",
      "\t/* استدعاء GetStdHandle(-11) */",
      "\tmov x0, -11",
      "\tbl GetStdHandle",
      "",
      "\t/* استدعاء WriteConsoleA */",
      "\tldr x1, =msg",
      "\tldr x2, =len",
      "\tldr x3, =written",
      "\tmov x4, #0",
      "\tbl WriteConsoleA",
      "",
      "\tmov x0, #0",
      "\tldp x29, x30, [sp], #32",
      "\tret"
    ],
    "description": "Template for Windows ARM64 using main"
  },
  "win_arm32_start": {
    "prefix": "win-arm32-start",
    "body": [
      ".data",
      "\tmsg: .ascii \"hi i use arch btw by win-arm32\\n\"",
      "\tlen = . - msg",
      "",
      ".bss",
      "\t.align 2",
      "\twritten: .space 4",
      "",
      ".text",
      "\t.global _start",
      "",
      "_start:",
      "\t/* محاذاة المكدس بـ 8 بايت في ARM32 */",
      "\tsub sp, sp, #16",
      "",
      "\t/* استدعاء GetStdHandle(-11) */",
      "\tmov r0, #-11",
      "\tbl GetStdHandle",
      "",
      "\t/* استدعاء WriteConsoleA */",
      "\t/* r0 يحتوي على مقبض الشاشة */",
      "\tldr r1, =msg",
      "\tldr r2, =len",
      "\tldr r3, =written",
      "\tmov r4, #0",
      "\tstr r4, [sp]        /* المعامل الخامس في المكدس */",
      "\tbl WriteConsoleA",
      "",
      "\t/* استدعاء ExitProcess(0) */",
      "\tmov r0, #0",
      "\tbl ExitProcess"
    ],
    "description": "Template for Windows ARM32 using _start"
  },
  "win_arm32_main": {
    "prefix": "win-arm32-main",
    "body": [
      ".data",
      "\tmsg: .ascii \"hi i use arch btw by win-arm32\\n\"",
      "\tlen = . - msg",
      "",
      ".bss",
      "\t.align 2",
      "\twritten: .space 4",
      "",
      ".text",
      "\t.global main",
      "",
      "main:",
      "\t/* حفظ المسجلات (r4 و r7 و lr) في المكدس لضمان العودة الآمنة للـ CRT */",
      "\tpush {r4, r7, lr}",
      "\tadd r7, sp, #4",
      "",
      "\t/* محاذاة المكدس (Stack Alignment) */",
      "\tsub sp, sp, #8",
      "",
      "\t/* استدعاء GetStdHandle(-11) */",
      "\tmov r0, #-11",
      "\tbl GetStdHandle",
      "",
      "\t/* استدعاء WriteConsoleA */",
      "\tldr r1, =msg",
      "\tldr r2, =len",
      "\tldr r3, =written",
      "",
      "\tmov r4, #0",
      "\tstr r4, [sp]",
      "\tbl WriteConsoleA",
      "",
      "\t/* تجهيز قيمة الإرجاع 0 (Success) */",
      "\tmov r0, #0",
      "",
      "\t/* استعادة المكدس والمسجلات والعودة للـ CRT */",
      "\tadd sp, sp, #8",
      "\tpop {r4, r7, pc}"
    ],
    "description": "Template for Windows ARM32 using main"
  },
  "mac_arm64_main": {
    "prefix": "mac-arm64-main",
    "body": [
      ".data",
      "\tmsg: .ascii \"hi i use arch btw by mac-arm64\\n\"",
      "\tlen = . - msg",
      "",
      ".text",
      "\t.global _main",
      "\t.align 2",
      "",
      "_main:",
      "\t/* Stack alignment & saving registers */",
      "\tstp x29, x30, [sp, #-16]!",
      "\tmov x29, sp",
      "",
      "\t/* write(1, msg, len) */",
      "\tmov x0, #1",
      "\tadrp x1, msg@PAGE",
      "\tadd x1, x1, msg@PAGEOFF",
      "\tmov x2, len",
      "\tbl _write",
      "",
      "\t/* return 0 */",
      "\tmov x0, #0",
      "\tldp x29, x30, [sp], #16",
      "\tret"
    ],
    "description": "Template for macOS ARM64 using main (Apple Silicon)"
  },
  "FreeBSD 32-bit (_start)": {
    "prefix": "freebsd32-start",
    "body": [
      "section .data",
      "\tmsg db \"Hello from FreeBSD 32-bit on Arch Linux!\", 10",
      "\tlen equ $ - msg",
      "",
      "section .text",
      "\tglobal _start",
      "",
      "_start:",
      "\t; 1. sys_write (FreeBSD 32-bit expects args on stack)",
      "\tpush dword len      ; arg 3: length",
      "\tpush dword msg      ; arg 2: message pointer",
      "\tpush dword 1        ; arg 1: stdout",
      "\tpush dword 0        ; dummy return address",
      "\tmov eax, 4          ; sys_write",
      "\tint 0x80",
      "\tadd esp, 16         ; clean up stack",
      "",
      "\t; 2. sys_exit",
      "\tpush dword 0        ; arg 1: exit status",
      "\tpush dword 0        ; dummy return address",
      "\tmov eax, 1          ; sys_exit",
      "\tint 0x80"
    ],
    "description": "Template for FreeBSD 32-bit using _start (Stack Syscalls)"
  },
  "FreeBSD 32-bit (main)": {
    "prefix": "freebsd32-main",
    "body": [
      "; freebsd32_main.asm - FreeBSD 32-bit using main",
      "section .data",
      "\tmsg db \"hi i use arch btw by freebsd32 (main)\", 10",
      "\tlen equ $ - msg",
      "",
      "section .text",
      "\tglobal main",
      "",
      "main:",
      "\t; 1. sys_write (FreeBSD 32-bit expects args on stack)",
      "\tpush dword len      ; المعامل الثالث: طول الرسالة",
      "\tpush dword msg      ; المعامل الثاني: عنوان الرسالة",
      "\tpush dword 1        ; المعامل الأول: stdout (1)",
      "",
      "\t; مساحة وهمية لعنوان العودة الخاص بالـ Syscall",
      "\tpush dword 0",
      "\tmov eax, 4          ; رقم أمر sys_write",
      "\tint 0x80",
      "\tadd esp, 16         ; تنظيف المكدس",
      "",
      "\t; 2. sys_exit",
      "\tpush dword 0        ; حالة الخروج (Status = 0)",
      "\tpush dword 0        ; مساحة وهمية لعنوان العودة",
      "\tmov eax, 1          ; رقم أمر sys_exit",
      "\tint 0x80"
